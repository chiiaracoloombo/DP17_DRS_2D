FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];
#include        "../initialConditions";
internalField   uniform $flowVelocity;

boundaryField
{
    front
    {
        type            empty;
    }
    back
    {
        type            empty;
    }
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform (0 0 0);
        value           $internalField;
    }
    topAndBottom
    {
        type            slip;
    }
    "(RW|F1|F2|U3)"
    {
        type            movingWallVelocity;
        value           uniform (0 0 0);
    }
    ".*overset.*"
    {
        type            overset;
        value           uniform (0 0 0);
    }
}
