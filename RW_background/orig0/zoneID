FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      zoneID;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    ".*"
    {
        type            zeroGradient;
    }
    
    // Add specific overset patches here if known, otherwise they default to zeroGradient 
    // until changed to 'overset' type in the boundary file or via changeDictionary
    ".*overset.*"
    {
        type            overset;
        value           uniform 0;
    }
}

