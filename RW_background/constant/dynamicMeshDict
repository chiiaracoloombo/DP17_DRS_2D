FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh       dynamicOversetFvMesh;
motionSolverLibs    ( "fvMotionSolvers.so" );

solver              multiSolidBodyMotionSolver; // Required for v2312 overset functionality

multiSolidBodyMotionSolverCoeffs
{
    movingZone2
    {
        solidBodyMotionFunction oscillatingRotatingMotion;
        oscillatingRotatingMotionCoeffs
        {
            cellZone movingZone2;
            origin      (1.88 -0.05 0.9);   // Centro F1 - Y a meta' spessore mesh 2D
            axis        (0 1 0);             // Rotazione attorno a Y (apertura alare)
            omega       2.0;
            amplitude   (0 70 0);      // ~10 gradi
        }
    }

    movingZone3
    {
        solidBodyMotionFunction oscillatingRotatingMotion;
        oscillatingRotatingMotionCoeffs
        {
            cellZone movingZone3;
            origin      (1.89 -0.05 1.0);   // Centro F2 - Y a meta' spessore mesh 2D
            axis        (0 1 0);
            omega       2.0;
            amplitude   (0 70 0);
        }
    }

    movingZone1
    {
        solidBodyMotionFunction oscillatingRotatingMotion;
        oscillatingRotatingMotionCoeffs
        {
            cellZone movingZone1;
            origin      (1.7 -0.05 1.0);    // Centro U3 - Y a meta' spessore mesh 2D
            axis        (0 1 0);
            omega       2.0;
            amplitude   (0 70 0);
        }
    }
}

