FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    RW.obj { type triSurfaceMesh; name RW; }
    F1.obj { type triSurfaceMesh; name F1; }
    F2.obj { type triSurfaceMesh; name F2; }
    // F3.obj { type triSurfaceMesh; name F3; }
    U3.obj { type triSurfaceMesh; name U3; }
}

castellatedMeshControls
{
    maxLocalCells 1000000;
    maxGlobalCells 2000000;
    minRefinementCells 10;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 3;

    features
    (
        { file "RW.eMesh"; level 8; }
        { file "F1.eMesh"; level 8; }
        { file "F2.eMesh"; level 8; }
        { file "U3.eMesh"; level 8; }
    );

    refinementSurfaces
    {
        RW { level (8 8); patchInfo { type wall; } }
        F1 { level (8 8); patchInfo { type wall; } }
        F2 { level (8 8); patchInfo { type wall; } }
        // F3 { level (8 8); patchInfo { type wall; } }
        U3 { level (8 8); patchInfo { type wall; } }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
    }

    locationInMesh (10 0 25);  // Changed Y from 0 to 25 (middle of thick domain)
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 2.0;
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;
    layers
    {
        RW { nSurfaceLayers 3; }
        F1 { nSurfaceLayers 3; }
        F2 { nSurfaceLayers 3; }
        // F3 { nSurfaceLayers 3; }
        U3 { nSurfaceLayers 3; }
    }

    expansionRatio 1.2;
    finalLayerThickness 0.5;
    minThickness 0.1;
    nGrow 0;
    featureAngle 60;
    slipFeatureAngle 30;
    nSmoothSurfaceNormals 1;
    nSmoothNormals 3;
    nSmoothThickness 10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedialAxisAngle 90;
    nBufferCellsNoExtrude 0;
    nLayerIter 50;
    nRelaxIter 5;
}

meshQualityControls
{
    #include "meshQualityDict"
}

writeFlags
(
    layerSets
    layerFields
);

mergeTolerance 1e-3;
