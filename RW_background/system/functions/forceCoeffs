#include "../../../initialConditions"

libs ( "libforces.so" );

RW_forceCoeffs
{
    type        forceCoeffs;
    libs ( "libforces.so" );
    writeControl    timeStep;
    timeInterval    1;
    log         true;
    patches     ( RW );
    rho         rhoInf;
    rhoInf      1.225;
    liftDir     (0 0 1);
    dragDir     (1 0 0);
    CofR        (0 0.765 0);
    pitchAxis   (0 1 0);
    magUInf     16;
    lRef        1.53;
    Aref        1;
    porosity    false;
}

