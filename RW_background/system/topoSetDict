FoamFile
{
    version     1.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

actions
(


    {
        name c_F2;
        type cellSet;
        action new;
        source  fieldToCell;
        sourceInfo
        {
            field   cellToRegion;
            min     2; // Assuming Object 1 is Region 1
            max     2;
        }
    }

    {
        name c_F1;
        type cellSet;
        action new;
        source  fieldToCell;
        sourceInfo
        {
            field   cellToRegion;
            min     1; // Assuming Object 1 is Region 1
            max     1;
        }
    }


    {
        name c_U3;
        type cellSet;
        action new;
        source  fieldToCell;
        sourceInfo
        {
            field   cellToRegion;
            min     3; // Assuming Object 1 is Region 1
            max     3;
        }
    }

    {
        name BGGrid;
        type cellSet;
        action new;
        source cellToCell;
        sets (c_U3 c_F1 c_F2);
    }

    {
        name BGGrid;
        type cellSet;
        action invert;
    }
);



