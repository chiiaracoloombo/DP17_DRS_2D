#include	"../../../initialConditions"
DP_forces
{
    type        forces;

    libs ( "libforces.so" );

    writeControl    	writeTime;
executeControl   	writeTime;

    log         false;

    patches     (  "DP_.*"  );
    pName       p;
    UName       Urel;
    rhoName     rho;
    rhoInf      $rho;          // Redundant for incompressible
    rho         rhoInf;     // Indicates incompretimeInterval    $iterations;ssible

    CofR        $CR;    // Rotation centre
    pitchAxis   $pitch;
    porosity    false;
}
