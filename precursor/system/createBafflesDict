internalFacesOnly true;
// Baffles to create.
baffles
{
    Battery_Fan_lower // =====================================================================================
    {
        //- Select faces and orientation through a searchableSurface
        type		searchableSurface;
        surface	triSurfaceMesh;	
        name		FanDiskBatterySurface2_lower.obj;

        patches
        {	   
            master
            {
                //- Master side patch

                name            FanDiskBattery_lower_half0;
                type            cyclic;
                neighbourPatch  FanDiskBattery_lower_half1;

                patchFields
                {
                    	p
		        {
		            type            fan;
		            patchType       cyclic;
		            value           uniform 0;
		            jumpTable       csvFile;
		            jumpTableCoeffs
		            {
		                nHeaderLine     1;
		                refColumn       0;
		                componentColumns 1(1);
		                separator       ",";
		                mergeSeparators no;
		                file            "$FOAM_CASE/constant/fanCurve_battery.csv";
		            }
		        }
                }
            }
            slave
            {
                //- Slave side patch

                name            FanDiskBattery_lower_half1;
                type            cyclic;
                neighbourPatch  FanDiskBattery_lower_half0;

                patchFields
                {
                    	p
		        {
		            type            fan;
		            patchType       cyclic;
		            value           uniform 0;
		            jumpTable       csvFile;
