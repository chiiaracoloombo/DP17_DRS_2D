FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
scale 1;
xmin 1.825; xmax 1.975;
ymin 0; ymax 0.0125;
zmin 0.95; zmax 1.1;

vertices
(
    ($xmin $ymin $zmin)
    ($xmax $ymin $zmin)
    ($xmax $ymax $zmin)
    ($xmin $ymax $zmin)
    ($xmin $ymin $zmax)
    ($xmax $ymin $zmax)
    ($xmax $ymax $zmax)
    ($xmin $ymax $zmax)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (12 1 12) simpleGrading (1 1 1)
);

boundary
(
    overset
    {
        type overset;
        faces
        (
            (0 3 2 1)
            (4 5 6 7)
            (0 4 7 3)
            (1 2 6 5)
        );
    }
    symFront
    {
        type symmetryPlane;
        faces ( (0 1 5 4) );
    }
    symBack
    {
        type symmetryPlane;
        faces ( (3 7 6 2) );
    }
);
