FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    F2.obj { type triSurfaceMesh; name F2; }

    refinementBox
    {
        type searchableBox;
        min (1.2 0.0 0.5); // Leggermente prima del profilo (X: 1.2, Z: 0.5)
        max (2.1 0.1 1.3); // Leggermente dopo e sopra (X: 2.1, Z: 1.3)
    }

    wake
    {
        type searchableBox;
        min (1.2 0.0 0.5); // Inizio zona ali
        max (6.0 0.1 1.5);  // Si estende verso outlet (X=5.0)
    }
}

castellatedMeshControls
{
    maxLocalCells 5000000;
    maxGlobalCells 10000000;
    minRefinementCells 10;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 2;

    features ( { file "F2.eMesh"; level 4; } );

    refinementSurfaces
    {
        F2 { level (2 3); patchInfo { type wall; } }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        F2
        { 
            mode distance;
            levels 
            ( 
                (0.01 3)  // vicino alla superficie
                (0.05 2)  // lontano dalla superficie
            ); 
        }

        refinementBox
        {
            mode inside;
            levels ( (1.0 1) ); 
        }
    }

    locationInMesh (1.85 0.002 0.97);
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 5;
    tolerance 4.0;
    nSolveIter 300;
    nRelaxIter 5;
    nFeatureSnapIter 20;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;
    layers { F2 { nSurfaceLayers 6; } }
    expansionRatio 1.2;
    finalLayerThickness 0.7;
    minThickness 0.05;
    nGrow 0;
    featureAngle 60;
    slipFeatureAngle 30;
    nSmoothSurfaceNormals 1;
    nSmoothNormals 3;
    nSmoothThickness 10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedialAxisAngle 90;
    nBufferCellsNoExtrude 0;
    nLayerIter 20;
    nRelaxIter 5;
}

meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-30;
    minArea -1;
    minTwist 0.01;
    minDeterminant 0.001;
    minFaceWeight 0.02;
    minVolRatio 0.01;
    triangleTwist -1;
    nSmoothScale 4;
    errorReduction 0.75;
    minTriangleTwist    -1;
}

writeFlags ( layerSets layerFields );
mergeTolerance 1e-3;
